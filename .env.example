# ─────────────────────────────────────────────────────────────────────────────
# SpectraCleanse AI – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before starting the server.
# Never commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port the Node.js backend listens on (Hyperlift expects 3001)
PORT=3001

# Absolute URL of your frontend (used for CORS and Stripe redirects)
# Local default can be http://localhost:5173
FRONTEND_URL=https://spectracleanse.com

# Optionally restrict CORS to a different origin than FRONTEND_URL
# ALLOWED_ORIGIN=https://spectracleanse.com


# ── Auth ──────────────────────────────────────────────────────────────────────

# Long, random string used to sign JWT tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string


# ── Database ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file (relative to the working directory)
# On Hyperlift, mount a persistent volume at /data and set this accordingly
DB_PATH=/data/spectra.db


# ── Stripe ────────────────────────────────────────────────────────────────────
# Find these in your Stripe Dashboard → Developers → API keys / Webhooks

STRIPE_SECRET_KEY=sk_live_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# Price IDs for subscription products (Stripe Dashboard → Products)
STRIPE_CREATOR_PRICE_ID=price_replace_with_creator_plan_price_id
STRIPE_STUDIO_PRICE_ID=price_replace_with_studio_plan_price_id

# Local development helper:
# If Stripe keys are missing and this is true, checkout returns a mock success redirect.
ENABLE_MOCK_CHECKOUT=false


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Used by /api/generate-seo to generate AI-powered metadata.
# Create a key at https://aistudio.google.com/app/apikey

GEMINI_API_KEY=replace_with_your_gemini_api_key


# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These variables must be prefixed with VITE_ to be exposed to the browser.
# Set this in your frontend build environment (not in the backend .env).

VITE_BACKEND_URL=https://api.spectracleanse.com
